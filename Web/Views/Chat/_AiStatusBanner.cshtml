@model Service.DTOs.AiStatusDto
@{
    var statusClass = Model.IsOnline ? "online" : Model.ConfiguredForAi ? "warning" : "offline";
    var iconClass   = Model.IsOnline ? "bi-check-circle-fill" : Model.ConfiguredForAi ? "bi-exclamation-triangle-fill" : "bi-cpu";
    var iconColor   = Model.IsOnline ? "#34d399" : Model.ConfiguredForAi ? "#fbbf24" : "var(--text-3)";
    var title       = Model.IsOnline
        ? $"AI · {Model.Provider} ({Model.Model})"
        : Model.ConfiguredForAi
            ? $"AI · {Model.Provider} — chưa kết nối"
            : "Chế độ local — không dùng model AI";
}
<div class="ai-status-banner @statusClass" role="status">
    <i class="bi @iconClass" style="font-size:1.15rem;color:@iconColor;flex-shrink:0;margin-top:1px;"></i>
    <div class="flex-grow-1">
        <strong style="color:var(--text);font-size:.9rem;">@title</strong>
        <span class="d-block mt-1" style="font-size:.82rem;color:var(--text-2);">@Model.Message</span>
        @if (Model.ConfiguredForAi && !Model.IsOnline)
        {
            <div class="mt-2" style="font-size:.8rem;color:var(--text-2);">
                Mở app <strong style="color:var(--text)">Ollama</strong> → chạy
                <code>ollama pull @Model.Model</code> → F5 trang này.
            </div>
        }
    </div>
</div>
