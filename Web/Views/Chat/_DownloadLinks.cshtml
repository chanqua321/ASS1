@model IReadOnlyList<Service.DTOs.DocumentLinkDto>
@if (Model.Count > 0)
{
    <div class="download-links-box">
        <div class="small fw-semibold mb-2">
            <i class="bi bi-file-earmark-arrow-down me-1"></i> Tài liệu liên quan
        </div>
        <div class="d-flex flex-wrap gap-2">
            @foreach (var doc in Model)
            {
                <a asp-controller="Documents" asp-action="Download" asp-route-id="@doc.DocumentId"
                   class="btn btn-sm btn-outline-primary" download>
                    <i class="bi bi-download me-1"></i>@doc.FileName
                </a>
            }
        </div>
    </div>
}
