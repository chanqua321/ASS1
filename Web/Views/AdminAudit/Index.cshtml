@model IReadOnlyList<BusinessLogic.DTOs.AuditLogDto>
@{
    ViewData["Title"] = "Audit Log";
}

<div class="page-header">
    <h1><i class="bi bi-journal-check me-2"></i>Audit Log</h1>
    <p class="page-subtitle">Lịch sử hành động quan trọng trong hệ thống.</p>
</div>

<div class="app-card">
    <div class="card-body p-0 app-table-wrap" style="border:none;box-shadow:none;background:transparent;">
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Thời gian</th>
                        <th>User</th>
                        <th>Hành động</th>
                        <th>IP</th>
                        <th>Chi tiết</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td class="text-muted small" style="white-space:nowrap;">@log.CreatedAt.ToLocalTime().ToString("g")</td>
                        <td class="fw-semibold">@log.Username</td>
                        <td><span class="badge bg-light">@log.Action</span></td>
                        <td class="text-muted small">@(log.IpAddress ?? "—")</td>
                        <td class="small">@(log.Detail ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
