@{
    ViewData["Title"] = "Trang chủ";
}

<div class="hero-card">
    <div class="hero-card-inner">
        <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:52px;height:52px;border-radius:14px;background:rgba(255,255,255,.12);display:flex;align-items:center;justify-content:center;font-size:1.6rem;backdrop-filter:blur(8px);">
                🎓
            </div>
            <span style="font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.6);">
                PRN222 · Assignment 1
            </span>
        </div>
        <h1>Chào mừng đến EduAI</h1>
        <p class="hero-lead">
            Tải bài học lên, hỏi đáp và tóm tắt tài liệu ngay trên trình duyệt —
            trợ lý AI đọc hiểu tài liệu giúp bạn học nhanh và sâu hơn.
        </p>
        <div class="d-flex gap-3 mt-4 flex-wrap">
            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher"))
            {
                <a asp-controller="Documents" asp-action="Upload" class="btn btn-primary px-4">
                    <i class="bi bi-cloud-upload me-2"></i>Upload tài liệu
                </a>
            }
            <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-secondary px-4" style="border-color:rgba(255,255,255,.25);color:rgba(255,255,255,.85);">
                <i class="bi bi-chat-heart me-2"></i>Vào Chat AI
            </a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <a asp-controller="Documents" asp-action="Index" class="hero-quick-link">
            <div class="icon-wrap"><i class="bi bi-folder2-open"></i></div>
            <h3>Kho Tài Liệu</h3>
            <p>Xem danh sách, chi tiết trạng thái xử lý và tải file bài học của bạn.</p>
            <div class="mt-3 d-flex align-items-center gap-1" style="font-size:.8rem;color:var(--c-indigo-light);font-weight:600;">
                Xem ngay <i class="bi bi-arrow-right"></i>
            </div>
        </a>
    </div>
    <div class="col-md-4">
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher"))
        {
            <a asp-controller="Documents" asp-action="Upload" class="hero-quick-link">
                <div class="icon-wrap"><i class="bi bi-cloud-arrow-up"></i></div>
                <h3>Upload Bài Học</h3>
                <p>Thêm PDF, Word hoặc slide theo môn và chương — tự động chia chunk & lập chỉ mục.</p>
                <div class="mt-3 d-flex align-items-center gap-1" style="font-size:.8rem;color:var(--c-indigo-light);font-weight:600;">
                    Upload ngay <i class="bi bi-arrow-right"></i>
                </div>
            </a>
        }
    </div>
    <div class="col-md-4">
        <a asp-controller="Chat" asp-action="Index" class="hero-quick-link">
            <div class="icon-wrap"><i class="bi bi-chat-heart"></i></div>
            <h3>Chat với AI</h3>
            <p>Hỏi bài, tóm tắt file và trò chuyện với trợ lý học tập được hỗ trợ bởi Ollama.</p>
            <div class="mt-3 d-flex align-items-center gap-1" style="font-size:.8rem;color:var(--c-indigo-light);font-weight:600;">
                Bắt đầu chat <i class="bi bi-arrow-right"></i>
            </div>
        </a>
    </div>
</div>

<div class="row g-4 mt-2">
    <div class="col-12">
        <div class="app-card" style="background:linear-gradient(135deg,rgba(99,102,241,.08) 0%,var(--surface-1) 100%);">
            <div class="card-body py-4">
                <div class="row g-4 text-center">
                    <div class="col-6 col-md-3">
                        <div style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--c-indigo-light),var(--c-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">RAG</div>
                        <div style="font-size:.8rem;color:var(--text-2);margin-top:.25rem;">Retrieval-Augmented</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--c-violet),var(--c-indigo-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">PDF</div>
                        <div style="font-size:.8rem;color:var(--text-2);margin-top:.25rem;">Word · Slide hỗ trợ</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--c-cyan),var(--c-emerald));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">AI</div>
                        <div style="font-size:.8rem;color:var(--text-2);margin-top:.25rem;">Ollama Local LLM</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div style="font-size:2rem;font-weight:900;background:linear-gradient(135deg,var(--c-emerald),var(--c-amber));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">∞</div>
                        <div style="font-size:.8rem;color:var(--text-2);margin-top:.25rem;">Phiên chat không giới hạn</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
