@model Web.ViewModels.AdminTeachersIndexViewModel
@{
    ViewData["Title"] = "Admin · Tạo giáo viên";
    var errors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .Distinct()
        .ToList();
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
    <div>
        <h1><i class="bi bi-person-workspace me-2"></i>Tạo giáo viên & gán môn</h1>
        <p class="page-subtitle mb-0">
            Một giáo viên có thể phụ trách <strong>nhiều môn</strong>; mỗi môn chỉ có <strong>đúng một</strong> giáo viên.
            Chưa có môn?
            <a asp-controller="AdminSubjects" asp-action="Create">Tạo môn mới</a>
        </p>
    </div>
    <a asp-controller="AdminSubjects" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-book me-1"></i> Quản lý môn học
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="app-card">
            <div class="app-card-header">
                <i class="bi bi-person-plus me-2" style="color:var(--c-indigo-light)"></i>Gán giáo viên cho môn
            </div>
            <div class="card-body">
                @if (errors.Count > 0)
                {
                    <div class="alert alert-danger py-2 mb-3" role="alert">
                        <ul class="mb-0 ps-3">
                            @foreach (var msg in errors) { <li>@msg</li> }
                        </ul>
                    </div>
                }

                @if (!Model.AvailableSubjects.Any())
                {
                    <div class="alert alert-warning py-2 mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Tất cả môn đã có giáo viên hoặc chưa có môn nào.
                        <a asp-controller="AdminSubjects" asp-action="Create" class="alert-link">Tạo môn</a>
                    </div>
                }

                <form asp-action="Index" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="SubjectId" class="form-label">Môn học</label>
                        <select asp-for="SubjectId" asp-items="Model.AvailableSubjects" class="form-select">
                            <option value="">— Chọn môn chưa có GV —</option>
                        </select>
                        <span asp-validation-for="SubjectId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email giáo viên</label>
                        <input asp-for="Email" class="form-control" type="email" autocomplete="username"
                               placeholder="teacher@gmail.com" />
                        <div class="form-text">GV đã có tài khoản: nhập cùng email để gán thêm môn — không cần mật khẩu.</div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Mật khẩu</label>
                        <input asp-for="Password" class="form-control" type="password" autocomplete="new-password"
                               data-val="false" data-val-required="false" />
                        <div class="form-text">Bắt buộc chỉ khi tạo tài khoản giáo viên mới (email chưa có trong hệ thống).</div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100" disabled="@(!Model.AvailableSubjects.Any())">
                        <i class="bi bi-check2-circle me-2"></i> Tạo / gán giáo viên
                    </button>
                </form>
            </div>
        </div>

        @if (Model.UnassignedSubjects.Any())
        {
            <div class="app-card mt-4">
                <div class="app-card-header">
                    <i class="bi bi-exclamation-circle me-2" style="color:var(--c-amber)"></i>Môn chưa có GV (@Model.UnassignedSubjects.Count)
                </div>
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush" style="background:transparent;">
                        @foreach (var s in Model.UnassignedSubjects)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center"
                                style="background:transparent;border-color:var(--border);color:var(--text);">
                                <span><strong>@s.Code</strong> — @s.Name</span>
                                <a asp-action="Index" asp-route-subjectId="@s.Id" class="btn btn-sm btn-outline-primary">Chọn</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-7">
        <div class="app-card">
            <div class="app-card-header">
                <i class="bi bi-people me-2" style="color:var(--c-emerald)"></i>Giáo viên & môn đang phụ trách
            </div>
            <div class="card-body p-0 app-table-wrap" style="border:none;box-shadow:none;background:transparent;">
                @if (!Model.Teachers.Any())
                {
                    <div class="empty-state py-5 px-3">
                        <p class="text-muted mb-0">Chưa có giáo viên nào được gán môn.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Email giáo viên</th>
                                    <th>Môn phụ trách</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var t in Model.Teachers)
                            {
                                <tr>
                                    <td class="fw-semibold">@t.Email</td>
                                    <td>
                                        @foreach (var sub in t.Subjects)
                                        {
                                            <span class="badge bg-success me-1 mb-1">@sub</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
