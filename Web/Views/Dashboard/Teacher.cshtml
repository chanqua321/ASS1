@model BusinessLogic.DTOs.TeacherDashboardDto
@{
    ViewData["Title"] = "Dashboard Giáo viên";
}

<div class="page-header">
    <h1><i class="bi bi-speedometer2 me-2" style="color:var(--c-indigo-light)"></i>Dashboard Giáo viên</h1>
    <p class="page-subtitle">Thống kê môn phụ trách, tài liệu và hoạt động chat của sinh viên.</p>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(99,102,241,.15);color:var(--c-indigo-light)"><i class="bi bi-book"></i></div>
            <div class="dash-stat-value">@Model.SubjectCount</div>
            <div class="dash-stat-label">Môn phụ trách</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(6,182,212,.15);color:var(--c-cyan)"><i class="bi bi-file-earmark-text"></i></div>
            <div class="dash-stat-value">@Model.DocumentCount</div>
            <div class="dash-stat-label">Tài liệu đã upload</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(139,92,246,.15);color:var(--c-violet)"><i class="bi bi-layers"></i></div>
            <div class="dash-stat-value">@Model.ChunkCount</div>
            <div class="dash-stat-label">Tổng chunks</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(16,185,129,.15);color:var(--c-emerald)"><i class="bi bi-chat-dots"></i></div>
            <div class="dash-stat-value">@Model.StudentChatMessageCount</div>
            <div class="dash-stat-label">Lượt chat (SV)</div>
        </div>
    </div>
</div>

<div class="app-card">
    <div class="app-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="bi bi-clock-history me-2" style="color:var(--c-indigo-light)"></i>Tài liệu mới nhất</span>
        <a asp-controller="Documents" asp-action="Upload" class="btn btn-sm btn-primary">
            <i class="bi bi-cloud-upload me-1"></i> Upload mới
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentDocuments.Any())
        {
            <div class="empty-state py-5">
                <p class="text-muted mb-0">Chưa có tài liệu nào. Hãy upload bài học cho môn bạn phụ trách.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Môn</th>
                            <th>Chương</th>
                            <th>Upload</th>
                            <th>Tóm tắt</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var doc in Model.RecentDocuments)
                    {
                        <tr>
                            <td class="fw-medium">@doc.FileName</td>
                            <td>@doc.SubjectName</td>
                            <td class="text-muted">@(doc.ChapterTitle ?? "—")</td>
                            <td class="text-muted small">@doc.UploadedAt.ToLocalTime().ToString("g")</td>
                            <td class="small text-muted" style="max-width:200px;">@(doc.SummaryPreview ?? "—")</td>
                            <td>
                                <a asp-controller="Documents" asp-action="Details" asp-route-id="@doc.Id" class="btn btn-sm btn-link">Chi tiết</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
