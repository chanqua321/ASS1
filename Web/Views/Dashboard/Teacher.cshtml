@model BusinessLogic.DTOs.TeacherDashboardDto
@{
    ViewData["Title"] = "Dashboard Giáo viên";
    ViewData["WideLayout"] = true;
}

<div class="page-header">
    <h1><i class="bi bi-speedometer2 me-2" style="color:var(--c-indigo-light)"></i>Dashboard Giáo viên</h1>
    <p class="page-subtitle">
        Thống kê các môn bạn phụ trách, tài liệu và hoạt động chat của sinh viên.
        Một giáo viên có thể phụ trách <strong>nhiều môn</strong>; mỗi môn chỉ có <strong>đúng một</strong> giáo viên.
    </p>
</div>

<div class="teacher-rule-banner mb-4" role="note">
    <i class="bi bi-diagram-3 me-2" aria-hidden="true"></i>
    <span>
        <strong>Quy tắc gán môn:</strong> Admin gán từng môn cho một giáo viên.
        Cùng email giáo viên có thể được gán thêm môn khác — bạn chỉ upload/chat trên các môn mình phụ trách.
    </span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(99,102,241,.15);color:var(--c-indigo-light)"><i class="bi bi-book"></i></div>
            <div class="dash-stat-value">@Model.SubjectCount</div>
            <div class="dash-stat-label">Môn phụ trách</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(6,182,212,.15);color:var(--c-cyan)"><i class="bi bi-file-earmark-text"></i></div>
            <div class="dash-stat-value">@Model.DocumentCount</div>
            <div class="dash-stat-label">Tài liệu đã upload</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(139,92,246,.15);color:var(--c-violet)"><i class="bi bi-layers"></i></div>
            <div class="dash-stat-value">@Model.ChunkCount</div>
            <div class="dash-stat-label">Tổng chunks</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="dash-stat-card">
            <div class="dash-stat-icon" style="background:rgba(16,185,129,.15);color:var(--c-emerald)"><i class="bi bi-chat-dots"></i></div>
            <div class="dash-stat-value">@Model.StudentChatMessageCount</div>
            <div class="dash-stat-label">Lượt chat (SV)</div>
        </div>
    </div>
</div>

<div class="app-card">
    <div class="app-card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="bi bi-clock-history me-2" style="color:var(--c-indigo-light)"></i>Tài liệu mới nhất</span>
        <a asp-controller="Documents" asp-action="Upload" class="btn btn-sm btn-primary">
            <i class="bi bi-cloud-upload me-1"></i> Upload mới
        </a>
    </div>
    <div class="card-body p-0">
        @if (!Model.RecentDocuments.Any())
        {
            <div class="empty-state py-5">
                <p class="text-muted mb-0">Chưa có tài liệu nào. Hãy upload bài học cho môn bạn phụ trách.</p>
            </div>
        }
        else
        {
            <div class="dash-table-wrap">
                <table class="table doc-table dash-recent-table align-middle mb-0">
                    <colgroup>
                        <col class="dash-col-file" />
                        <col class="dash-col-subject" />
                        <col class="dash-col-chapter" />
                        <col class="dash-col-date" />
                        <col class="dash-col-summary" />
                        <col class="dash-col-actions" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>File</th>
                            <th>Môn</th>
                            <th>Chương</th>
                            <th>Upload</th>
                            <th>Tóm tắt</th>
                            <th class="text-end doc-actions-header" scope="col">
                                <span class="visually-hidden">Thao tác</span>
                                <i class="bi bi-eye" aria-hidden="true"></i>
                            </th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var doc in Model.RecentDocuments)
                    {
                        <tr>
                            <td>
                                <span class="cell-ellipsis fw-medium doc-file-name" title="@doc.FileName">@doc.FileName</span>
                            </td>
                            <td>
                                <span class="cell-ellipsis doc-subject" title="@doc.SubjectName">@doc.SubjectName</span>
                            </td>
                            <td>
                                <span class="cell-ellipsis text-muted doc-chapter" title="@doc.ChapterTitle">@(doc.ChapterTitle ?? "—")</span>
                            </td>
                            <td>
                                <span class="doc-date">@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</span>
                            </td>
                            <td class="doc-summary-cell">
                                @if (!string.IsNullOrWhiteSpace(doc.SummaryPreview))
                                {
                                    <span class="cell-clamp-2" title="@doc.SummaryPreview">@doc.SummaryPreview</span>
                                }
                                else
                                {
                                    <span class="doc-summary-empty">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-controller="Documents" asp-action="Details" asp-route-id="@doc.Id"
                                   class="btn btn-sm btn-outline-primary btn-icon" title="Chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
