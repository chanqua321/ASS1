@model Web.ViewModels.CreateSubjectViewModel
@{
    ViewData["Title"] = "Admin · Tạo môn học";
}

<div class="page-header">
    <a asp-action="Index" class="back-link d-inline-flex align-items-center mb-3">
        <i class="bi bi-arrow-left me-1"></i> Quản lý môn học
    </a>
    <h1><i class="bi bi-bookmark-plus me-2"></i>Tạo môn học mới</h1>
    <p class="page-subtitle">Sau khi tạo môn, thêm chương và gán Teacher cho môn đó.</p>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="app-card">
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2 mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" placeholder="VD: PRN222" maxlength="20" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="VD: ASP.NET Core Back-End" maxlength="200" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2" placeholder="Mô tả ngắn (tuỳ chọn)"></textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-save me-2"></i> Lưu môn học
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
