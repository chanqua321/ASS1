@model Web.ViewModels.DocumentUploadViewModel
@using Web.ViewModels
@{
    ViewData["Title"] = "Upload tài liệu";
    var isNewSubject = Model.SubjectInputMode == DocumentUploadViewModel.ModeNew;
}

<div class="page-header">
    <h1><i class="bi bi-cloud-upload me-2" style="font-size:.9em;vertical-align:middle;background:linear-gradient(135deg,var(--c-indigo-light),var(--c-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i>Upload Tài Liệu</h1>
    <p class="page-subtitle">Tải bài PDF, Word hoặc slide — xử lý xong là có thể hỏi đáp ngay trên Chat AI.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="app-card">
            <div class="app-card-header">
                <i class="bi bi-file-earmark-arrow-up me-2" style="color:var(--c-indigo-light)"></i>
                Thông tin tài liệu
            </div>
            <div class="card-body">
                @* UI: submit form "Tải lên & xử lý" → POST /Documents/Upload → DocumentsController.Upload (HttpPost) *@
                <form asp-action="Upload" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-4"></div>

                    <div class="mb-4 file-upload-zone" id="dropZone">
                        <span class="upload-icon"><i class="bi bi-cloud-arrow-up"></i></span>
                        <label asp-for="File" class="form-label fw-semibold d-block mb-1" style="font-size:1.05rem;color:var(--text);">
                            Kéo & thả file vào đây, hoặc click để chọn
                        </label>
                        <p class="small mb-3" style="color:var(--text-2);">PDF, Word (.docx) hoặc PowerPoint (.pptx, .ppt)</p>
                        <input asp-for="File" class="form-control" type="file" accept=".pdf,.docx,.pptx,.ppt" id="fileInput" />
                        <span asp-validation-for="File" class="text-danger small d-block mt-2"></span>
                        <div id="filePreview" class="mt-3 d-none">
                            <span class="badge bg-primary py-2 px-3" style="font-size:.85rem;">
                                <i class="bi bi-file-earmark-check me-2"></i>
                                <span id="fileName"></span>
                            </span>
                        </div>
                    </div>

                    <fieldset class="app-fieldset mb-4">
                        <legend><i class="bi bi-book me-1"></i> Môn học / Topic</legend>

                        <div class="mb-2">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="SubjectInputMode" id="modeExisting"
                                       value="@DocumentUploadViewModel.ModeExisting" checked />
                                <label class="form-check-label" for="modeExisting">Chọn môn được phân công</label>
                            </div>
                        </div>
                        <div class="form-text mb-3">
                            <i class="bi bi-shield-check me-1"></i>
                            Teacher chỉ upload được cho môn mà Admin đã gán.
                        </div>

                        <div id="existingSubjectBlock" class="@(isNewSubject ? "d-none" : "")">
                            <label asp-for="SubjectId" class="form-label"></label>
                            <select asp-for="SubjectId" asp-items="Model.Subjects" class="form-select" id="subjectSelect">
                                <option value="">— Chọn môn học —</option>
                            </select>
                            <span asp-validation-for="SubjectId" class="text-danger small"></span>
                        </div>

                        @* Teacher không tạo môn mới tại đây *@
                    </fieldset>

                    <fieldset class="app-fieldset mb-4">
                        <legend><i class="bi bi-collection me-1"></i> Chương</legend>
                        <p class="form-text mb-3">
                            <i class="bi bi-info-circle me-1"></i>
                            Mỗi chương chỉ được <strong>một</strong> tài liệu. Nếu cần cập nhật, dùng <strong>Index lại</strong> trên file hiện có.
                        </p>

                        <div class="mb-3" id="existingChapterBlock">
                            <label asp-for="ChapterId" class="form-label"></label>
                            <select asp-for="ChapterId" class="form-select" id="chapterSelect">
                                <option value="">— Không chọn chương —</option>
                                @foreach (var chapter in Model.Chapters)
                                {
                                    <option value="@chapter.Value" selected="@chapter.Selected">@chapter.Text</option>
                                }
                            </select>
                            <span asp-validation-for="ChapterId" class="text-danger small"></span>
                        </div>

                        <div>
                            <label asp-for="NewChapterTitle" class="form-label"></label>
                            <input asp-for="NewChapterTitle" class="form-control" placeholder="VD: Chương 3 - Xử lý ngôn ngữ tự nhiên" />
                            <div class="form-text"><i class="bi bi-info-circle me-1"></i>Nhập tên chương mới thay vì chọn trong danh sách.</div>
                            <span asp-validation-for="NewChapterTitle" class="text-danger small"></span>
                        </div>
                    </fieldset>

                    <div class="d-flex flex-wrap gap-3 pt-2">
                        <button type="submit" class="btn btn-primary px-4" id="submitBtn">
                            <i class="bi bi-upload me-2"></i> Tải lên &amp; xử lý
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="app-card info-card">
            <div class="card-body">
                <h6 class="card-title mb-3">
                    <i class="bi bi-info-circle me-1"></i> Hướng dẫn
                </h6>
                <ol class="small mb-0 ps-3" style="color:var(--text-2);">
                    <li class="mb-2">Chọn file PDF, Word hoặc Slide từ máy tính</li>
                    <li class="mb-2">Gán môn học hoặc tạo môn mới</li>
                    <li class="mb-2">Chọn chương nếu có (tuỳ chọn)</li>
                    <li class="mb-2">Nhấn <strong style="color:var(--c-indigo-light)">Tải lên & xử lý</strong></li>
                    <li>Sau khi <strong style="color:#34d399">Indexed</strong>, vào Chat để hỏi đáp</li>
                </ol>
                <hr style="border-color:var(--border);margin:1rem 0;">
                <div class="d-flex flex-column gap-2" style="font-size:.8rem;color:var(--text-3);">
                    <span><i class="bi bi-check-circle text-success me-2"></i>PDF — văn bản đầy đủ</span>
                    <span><i class="bi bi-check-circle text-success me-2"></i>Word .docx — hỗ trợ heading</span>
                    <span><i class="bi bi-check-circle text-success me-2"></i>PowerPoint .pptx/.ppt</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const modeExisting = document.getElementById('modeExisting');
        const existingBlock = document.getElementById('existingSubjectBlock');
        const chapterBlock  = document.getElementById('existingChapterBlock');
        const subjectSelect = document.getElementById('subjectSelect');
        const chapterSelect = document.getElementById('chapterSelect');
        const fileInput     = document.getElementById('fileInput');
        const filePreview   = document.getElementById('filePreview');
        const fileName      = document.getElementById('fileName');
        const dropZone      = document.getElementById('dropZone');
        const submitBtn     = document.getElementById('submitBtn');

        // File preview
        fileInput?.addEventListener('change', () => {
            if (fileInput.files[0]) {
                fileName.textContent = fileInput.files[0].name;
                filePreview.classList.remove('d-none');
                dropZone.style.borderColor = 'var(--c-emerald)';
                dropZone.style.boxShadow   = '0 0 32px rgba(16,185,129,.15)';
            }
        });

        // Drag & drop visual
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.borderColor = 'var(--c-indigo)'; });
        dropZone.addEventListener('dragleave', () => { dropZone.style.borderColor = ''; });
        dropZone.addEventListener('drop', e => {
            e.preventDefault();
            dropZone.style.borderColor = '';
            if (e.dataTransfer.files[0]) {
                fileInput.files = e.dataTransfer.files;
                fileInput.dispatchEvent(new Event('change'));
            }
        });

        // Submit loading state
        document.querySelector('form').addEventListener('submit', () => {
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status"></span>Đang xử lý...';
        });

        function toggleSubjectMode() {
            // Teacher: chỉ modeExisting
            existingBlock.classList.remove('d-none');
            chapterBlock.classList.remove('d-none');
        }

        modeExisting?.addEventListener('change', toggleSubjectMode);
        toggleSubjectMode();

        subjectSelect?.addEventListener('change', async function () {
            const subjectId = this.value;
            chapterSelect.innerHTML = '<option value="">— Không chọn chương —</option>';
            if (!subjectId) return;
            // UI: đổi môn học → gọi Controller lấy danh sách chapters (GET /Documents/ChaptersBySubject?subjectId=...)
            const response = await fetch(`/Documents/ChaptersBySubject?subjectId=${subjectId}`);
            const chapters = await response.json();
            chapters.forEach(c => {
                const opt = document.createElement('option');
                opt.value = c.id;
                opt.textContent = c.title;
                chapterSelect.appendChild(opt);
            });
        });
    </script>
}
