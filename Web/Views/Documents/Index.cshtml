@model Web.ViewModels.DocumentListViewModel
@using Model.Enums
@{
    ViewData["Title"] = "Kho tài liệu";
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
    <div>
        <h1><i class="bi bi-folder2-open me-2" style="font-size:.9em;vertical-align:middle;background:linear-gradient(135deg,var(--c-indigo-light),var(--c-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i>Kho Tài Liệu</h1>
        <p class="page-subtitle">Quản lý bài học đã tải lên, theo dõi trạng thái xử lý và tải xuống.</p>
    </div>
    <div class="page-header-actions">
        <a asp-action="Upload" class="btn btn-primary">
            <i class="bi bi-cloud-upload me-1"></i> Upload tài liệu mới
        </a>
    </div>
</div>

<form method="get" class="filter-bar row g-3 align-items-end mb-4">
    <div class="col-md-5">
        <label class="form-label"><i class="bi bi-funnel me-1"></i> Lọc theo môn học</label>
        <select name="subjectId" class="form-select" asp-for="FilterSubjectId" asp-items="Model.Subjects">
            <option value="">— Tất cả môn —</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">
            <i class="bi bi-search me-1"></i> Áp dụng
        </button>
    </div>
    @if (Model.FilterSubjectId.HasValue)
    {
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-1"></i> Xóa lọc
            </a>
        </div>
    }
</form>

<div class="app-table-wrap">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th><i class="bi bi-file-earmark me-1"></i>Tên file</th>
                    <th>Loại</th>
                    <th><i class="bi bi-book me-1"></i>Môn học</th>
                    <th>Chương</th>
                    <th><i class="bi bi-layers me-1"></i>Chunk</th>
                    <th>Trạng thái</th>
                    <th><i class="bi bi-calendar3 me-1"></i>Ngày upload</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @if (!Model.Documents.Any())
            {
                <tr>
                    <td colspan="8" class="p-0 border-0">
                        <div class="empty-state">
                            <div class="empty-state-icon"><i class="bi bi-inbox"></i></div>
                            <p class="fw-semibold mb-1">Chưa có tài liệu nào</p>
                            <p class="small mb-4">Upload file đầu tiên để bắt đầu hỏi đáp trên chat AI.</p>
                            <a asp-action="Upload" class="btn btn-primary">
                                <i class="bi bi-cloud-upload me-1"></i> Upload ngay
                            </a>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var doc in Model.Documents)
                {
                    <tr>
                        <td class="fw-medium">
                            @{
                                var ext = System.IO.Path.GetExtension(doc.FileName).ToLower();
                                var iconClass = ext switch {
                                    ".pdf"  => "bi-filetype-pdf",
                                    ".docx" => "bi-filetype-docx",
                                    ".pptx" or ".ppt" => "bi-filetype-pptx",
                                    _       => "bi-file-earmark-text"
                                };
                            }
                            <i class="bi @iconClass me-2 text-primary"></i>
                            @doc.FileName
                        </td>
                        <td><span class="badge bg-light">@doc.FileType</span></td>
                        <td>
                            <span style="color:var(--c-indigo-light);font-weight:500;">@doc.SubjectName</span>
                        </td>
                        <td class="text-muted" style="font-size:.88rem;">@(doc.ChapterTitle ?? "—")</td>
                        <td>
                            <span class="badge bg-primary">@doc.ChunkCount</span>
                        </td>
                        <td>
                            @{
                                var (bgClass, icon) = doc.Status switch {
                                    DocumentStatus.Indexed    => ("bg-success", "bi-check-circle-fill"),
                                    DocumentStatus.Processing => ("bg-warning", "bi-hourglass-split"),
                                    DocumentStatus.Failed     => ("bg-danger",  "bi-x-circle-fill"),
                                    _                         => ("bg-secondary","bi-clock")
                                };
                            }
                            <span class="badge @bgClass">
                                <i class="bi @icon me-1"></i>@doc.Status
                            </span>
                        </td>
                        <td class="text-muted" style="font-size:.82rem;white-space:nowrap;">
                            @doc.UploadedAt.ToLocalTime().ToString("g")
                        </td>
                        <td class="text-nowrap">
                            <a asp-action="Details" asp-route-id="@doc.Id" class="btn btn-sm btn-link">
                                <i class="bi bi-eye me-1"></i>Chi tiết
                            </a>
                            <a asp-action="Download" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-primary ms-1" title="Tải xuống">
                                <i class="bi bi-download"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            </tbody>
        </table>
    </div>
</div>

@if (Model.Documents.Any())
{
    <div class="mt-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Tổng <strong style="color:var(--text)">@Model.Documents.Count()</strong> tài liệu
        </span>
    </div>
}
