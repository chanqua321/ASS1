@model Web.ViewModels.DocumentListViewModel
@{
    ViewData["Title"] = "Kho tài liệu";
    ViewData["WideLayout"] = true;
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
    <div>
        <h1><i class="bi bi-folder2-open me-2" style="font-size:.9em;vertical-align:middle;background:linear-gradient(135deg,var(--c-indigo-light),var(--c-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i>Kho Tài Liệu</h1>
        <p class="page-subtitle">
            @if (User.IsInRole("Teacher"))
            {
                <text>Tài liệu các môn bạn phụ trách — mỗi chương hiển thị bản mới nhất.</text>
            }
            else
            {
                <text>Quản lý bài học đã tải lên, theo dõi trạng thái xử lý và tải xuống.</text>
            }
        </p>
    </div>
    <div class="page-header-actions">
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher"))
        {
            <a asp-action="Upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload me-1"></i> Upload tài liệu mới
            </a>
        }
    </div>
</div>

<form method="get" class="filter-bar row g-3 align-items-end mb-4">
    <div class="col-md-5">
        <label class="form-label"><i class="bi bi-funnel me-1"></i> Lọc theo môn học</label>
        <select name="subjectId" class="form-select" asp-for="FilterSubjectId" asp-items="Model.Subjects">
            <option value="">— Tất cả môn —</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">
            <i class="bi bi-search me-1"></i> Áp dụng
        </button>
    </div>
    @if (Model.FilterSubjectId.HasValue)
    {
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-1"></i> Xóa lọc
            </a>
        </div>
    }
</form>

<div class="app-table-wrap doc-table-wrap">
    <table class="table doc-table align-middle mb-0">
        <colgroup>
            <col class="doc-col-file" />
            <col class="doc-col-subject" />
            <col class="doc-col-chapter" />
            <col class="doc-col-chunk" />
            <col class="doc-col-summary" />
            <col class="doc-col-status" />
            <col class="doc-col-date" />
            <col class="doc-col-actions" />
        </colgroup>
        <thead>
            <tr>
                <th><i class="bi bi-file-earmark me-1"></i>Tên file</th>
                <th><i class="bi bi-book me-1"></i>Môn</th>
                <th>Chương</th>
                <th class="text-center"><i class="bi bi-layers"></i></th>
                <th><i class="bi bi-stars me-1"></i>Tóm tắt AI</th>
                <th>Trạng thái</th>
                <th><i class="bi bi-calendar3 me-1"></i>Upload</th>
                <th class="text-end doc-actions-header" scope="col">
                    <span class="visually-hidden">Thao tác</span>
                    <i class="bi bi-eye" aria-hidden="true"></i>
                </th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Documents.Any())
        {
            <tr>
                <td colspan="8" class="p-0 border-0">
                    <div class="empty-state">
                        <div class="empty-state-icon"><i class="bi bi-inbox"></i></div>
                        <p class="fw-semibold mb-1">Chưa có tài liệu nào</p>
                        <p class="small mb-4">
                            @(User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher")
                                ? "Upload file đầu tiên để bắt đầu hỏi đáp trên chat AI."
                                : "Chưa có tài liệu nào được giáo viên upload. Vui lòng quay lại sau hoặc vào Chat để hỏi khi đã có tài liệu.")
                        </p>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher"))
                        {
                            <a asp-action="Upload" class="btn btn-primary">
                                <i class="bi bi-cloud-upload me-1"></i> Upload ngay
                            </a>
                        }
                    </div>
                </td>
            </tr>
        }
        else
        {
            @foreach (var doc in Model.Documents)
            {
                var ext = System.IO.Path.GetExtension(doc.FileName).ToLower();
                var iconClass = ext switch {
                    ".pdf"  => "bi-filetype-pdf",
                    ".docx" => "bi-filetype-docx",
                    ".pptx" or ".ppt" => "bi-filetype-pptx",
                    _       => "bi-file-earmark-text"
                };
                <tr>
                    <td class="doc-file-cell">
                        <div class="doc-file-inner">
                            <i class="bi @iconClass doc-file-icon" aria-hidden="true"></i>
                            <div class="doc-file-text min-w-0">
                                <span class="cell-ellipsis doc-file-name" title="@doc.FileName">@doc.FileName</span>
                                <span class="doc-type-pill">@doc.FileTypeLabel</span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="cell-ellipsis doc-subject" title="@doc.SubjectDisplay">@doc.SubjectCode</span>
                    </td>
                    <td>
                        <span class="cell-ellipsis text-muted doc-chapter" title="@doc.ChapterTitle">@(doc.ChapterTitle ?? "—")</span>
                    </td>
                    <td class="text-center">
                        <span class="badge bg-primary doc-chunk-badge">@doc.ChunkCount</span>
                    </td>
                    <td class="doc-summary-cell">
                        @if (doc.HasSummary)
                        {
                            <span class="cell-clamp-2" title="@doc.Summary">@doc.SummaryPreview</span>
                        }
                        else if (doc.IsIndexed)
                        {
                            <span class="doc-summary-empty">Chưa có</span>
                        }
                        else
                        {
                            <span class="doc-summary-empty">—</span>
                        }
                    </td>
                    <td>
                        <span class="badge @doc.StatusBadgeClass doc-status-badge">
                            <i class="bi @doc.StatusIcon me-1"></i>@doc.StatusLabel
                        </span>
                    </td>
                    <td>
                        <span class="doc-date">@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")</span>
                    </td>
                    <td class="text-end">
                        <div class="doc-actions">
                            <a asp-action="Details" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-primary btn-icon" title="Chi tiết">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-action="Download" asp-route-id="@doc.Id" class="btn btn-sm btn-outline-secondary btn-icon" title="Tải xuống">
                                <i class="bi bi-download"></i>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>

@if (Model.Documents.Any())
{
    <div class="mt-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Tổng <strong style="color:var(--text)">@Model.Documents.Count()</strong> tài liệu
        </span>
    </div>
}
