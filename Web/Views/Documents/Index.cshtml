@model Web.ViewModels.DocumentListViewModel
@{
    ViewData["Title"] = "Kho tài liệu";
    ViewData["WideLayout"] = true;
}

<div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3">
    <div>
        <h1><i class="bi bi-folder2-open me-2" style="font-size:.9em;vertical-align:middle;background:linear-gradient(135deg,var(--c-indigo-light),var(--c-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i>Kho Tài Liệu</h1>
        <p class="page-subtitle">
            @if (User.IsInRole("Teacher"))
            {
                <text>Tài liệu các môn bạn phụ trách. Mỗi chương (tên tương tự) chỉ upload một lần.</text>
            }
            else
            {
                <text>Quản lý bài học đã tải lên, theo dõi trạng thái xử lý và tải xuống.</text>
            }
        </p>
    </div>
    <div class="page-header-actions">
        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher"))
        {
            <a asp-action="Upload" class="btn btn-primary">
                <i class="bi bi-cloud-upload me-1"></i> Upload tài liệu mới
            </a>
        }
    </div>
</div>

<form method="get" class="filter-bar row g-3 align-items-end mb-4">
    <div class="col-md-5">
        <label class="form-label"><i class="bi bi-funnel me-1"></i> Lọc theo môn học</label>
        <select name="subjectId" class="form-select" asp-for="FilterSubjectId" asp-items="Model.Subjects">
            <option value="">— Tất cả môn —</option>
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">
            <i class="bi bi-search me-1"></i> Áp dụng
        </button>
    </div>
    @if (Model.FilterSubjectId.HasValue)
    {
        <div class="col-auto">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-x-lg me-1"></i> Xóa lọc
            </a>
        </div>
    }
</form>

@if (!Model.Documents.Any())
{
    <div class="app-card">
        <div class="empty-state py-5">
            <div class="empty-state-icon"><i class="bi bi-inbox"></i></div>
            <p class="fw-semibold mb-1">Chưa có tài liệu nào</p>
            <p class="small mb-4">
                @(User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher")
                    ? "Upload file đầu tiên để bắt đầu hỏi đáp trên chat AI."
                    : "Chưa có tài liệu nào được giáo viên upload. Vui lòng quay lại sau hoặc vào Chat để hỏi khi đã có tài liệu.")
            </p>
            @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Teacher"))
            {
                <a asp-action="Upload" class="btn btn-primary">
                    <i class="bi bi-cloud-upload me-1"></i> Upload ngay
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="doc-list">
        @foreach (var doc in Model.Documents)
        {
            var ext = System.IO.Path.GetExtension(doc.FileName).ToLower();
            var iconClass = ext switch {
                ".pdf"  => "bi-filetype-pdf",
                ".docx" => "bi-filetype-docx",
                ".pptx" or ".ppt" => "bi-filetype-pptx",
                _       => "bi-file-earmark-text"
            };
            <article class="doc-card">
                <div class="doc-card-top">
                    <a asp-action="Details" asp-route-id="@doc.Id" class="doc-card-file-link">
                        <i class="bi @iconClass doc-card-icon" aria-hidden="true"></i>
                        <div class="doc-card-file-text">
                            <span class="doc-card-name" title="@doc.FileName">@doc.FileName</span>
                            <span class="doc-type-pill">@doc.FileTypeLabel</span>
                        </div>
                    </a>
                    <div class="dropdown doc-card-menu">
                        <button type="button" class="btn btn-sm btn-outline-secondary doc-menu-btn"
                                data-bs-toggle="dropdown" aria-expanded="false"
                                aria-label="Thao tác @doc.FileName">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow">
                            <li>
                                <a class="dropdown-item" asp-action="Details" asp-route-id="@doc.Id">
                                    <i class="bi bi-eye me-2"></i>Chi tiết
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-action="Download" asp-route-id="@doc.Id">
                                    <i class="bi bi-download me-2"></i>Tải xuống
                                </a>
                            </li>
                            @if (doc.CanDelete)
                            {
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-action="Delete" asp-route-id="@doc.Id" method="post" class="doc-delete-form">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger"
                                                onclick="return confirm('Xóa tài liệu này? Hành động không hoàn tác.');">
                                            <i class="bi bi-trash me-2"></i>Xóa
                                        </button>
                                    </form>
                                </li>
                            }
                        </ul>
                    </div>
                </div>

                <div class="doc-card-meta">
                    <span class="doc-meta-pill doc-meta-subject" title="@doc.SubjectDisplay">
                        <i class="bi bi-book me-1"></i>@doc.SubjectCode
                    </span>
                    @if (!string.IsNullOrWhiteSpace(doc.ChapterTitle))
                    {
                        <span class="doc-meta-pill" title="@doc.ChapterTitle">
                            <i class="bi bi-bookmark me-1"></i>@doc.ChapterTitle
                        </span>
                    }
                    <span class="badge @doc.StatusBadgeClass doc-status-badge">
                        <i class="bi @doc.StatusIcon me-1"></i>@doc.StatusLabel
                    </span>
                    <span class="doc-meta-pill doc-meta-muted">
                        <i class="bi bi-layers me-1"></i>@doc.ChunkCount chunk
                    </span>
                    <span class="doc-meta-pill doc-meta-muted">
                        <i class="bi bi-calendar3 me-1"></i>@doc.UploadedAt.ToLocalTime().ToString("dd/MM/yy HH:mm")
                    </span>
                </div>

                <div class="doc-card-summary">
                    @if (doc.IsIndexed && !doc.HasSearchableText)
                    {
                        <span class="text-warning small">
                            <i class="bi bi-exclamation-triangle me-1"></i>Chưa có text để chat —
                            <a asp-action="Details" asp-route-id="@doc.Id">xem hướng dẫn</a>
                        </span>
                    }
                    else if (doc.HasSummary)
                    {
                        <span class="doc-summary-preview" title="@doc.Summary">@doc.SummaryPreview</span>
                    }
                    else if (doc.IsIndexed)
                    {
                        <span class="doc-summary-empty">Tóm tắt AI: chưa có</span>
                    }
                    else
                    {
                        <span class="doc-summary-empty">—</span>
                    }
                </div>
            </article>
        }
    </div>

    <div class="mt-3">
        <span class="text-muted small">
            <i class="bi bi-info-circle me-1"></i>
            Tổng <strong style="color:var(--text)">@Model.Documents.Count</strong> tài liệu
        </span>
    </div>
}
