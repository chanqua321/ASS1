@model Service.DTOs.DocumentListItemDto
@using Model.Enums
@{
    ViewData["Title"] = "Chi tiết tài liệu";
}

<div class="page-header">
    <a asp-action="Index" class="back-link d-inline-block mb-2">
        <i class="bi bi-arrow-left"></i> Danh sách tài liệu
    </a>
    <h1>@Model.FileName</h1>
    <p class="page-subtitle">@Model.SubjectName · @Model.FileType</p>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="app-card">
            <div class="app-card-header">Thông tin file</div>
            <div class="card-body">
                <dl class="row detail-list mb-0">
                    <dt class="col-sm-4">Tên file</dt>
                    <dd class="col-sm-8">@Model.FileName</dd>

                    <dt class="col-sm-4">Loại</dt>
                    <dd class="col-sm-8"><span class="badge bg-light text-dark border">@Model.FileType</span></dd>

                    <dt class="col-sm-4">Môn học</dt>
                    <dd class="col-sm-8">@Model.SubjectName</dd>

                    <dt class="col-sm-4">Chương</dt>
                    <dd class="col-sm-8">@(Model.ChapterTitle ?? "—")</dd>

                    <dt class="col-sm-4">Số chunk</dt>
                    <dd class="col-sm-8">@Model.ChunkCount</dd>

                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-@(Model.Status switch {
                            DocumentStatus.Indexed => "success",
                            DocumentStatus.Processing => "warning",
                            DocumentStatus.Failed => "danger",
                            _ => "secondary"
                        })">@Model.Status</span>
                    </dd>

                    <dt class="col-sm-4">Upload</dt>
                    <dd class="col-sm-8">@Model.UploadedAt.ToLocalTime()</dd>

                    <dt class="col-sm-4">Xử lý xong</dt>
                    <dd class="col-sm-8 mb-0">@(Model.ProcessedAt?.ToLocalTime().ToString() ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="app-card action-card">
            <div class="app-card-header">Thao tác</div>
            <div class="card-body d-grid gap-2">
                <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-download me-1"></i> Tải file về
                </a>
                <form asp-action="Reindex" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-warning w-100">
                        <i class="bi bi-arrow-repeat me-1"></i> Index lại (chat tóm tắt)
                    </button>
                </form>
                <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-success">
                    <i class="bi bi-chat-dots me-1"></i> Mở Chat
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
            </div>
        </div>
    </div>
</div>
