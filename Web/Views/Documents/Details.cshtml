@model Service.DTOs.DocumentListItemDto
@using Model.Enums
@{
    ViewData["Title"] = "Chi tiết tài liệu";
    var (bgClass, statusIcon) = Model.Status switch {
        DocumentStatus.Indexed    => ("bg-success", "bi-check-circle-fill"),
        DocumentStatus.Processing => ("bg-warning",  "bi-hourglass-split"),
        DocumentStatus.Failed     => ("bg-danger",   "bi-x-circle-fill"),
        _                         => ("bg-secondary","bi-clock")
    };
}

<div class="page-header">
    <a asp-action="Index" class="back-link d-inline-flex align-items-center mb-3">
        <i class="bi bi-arrow-left me-1"></i> Danh sách tài liệu
    </a>
    <h1 class="d-flex align-items-center gap-2">
        <i class="bi bi-file-earmark-text" style="font-size:.85em;background:linear-gradient(135deg,var(--c-indigo-light),var(--c-cyan));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i>
        @Model.FileName
    </h1>
    <p class="page-subtitle">
        <span class="badge @bgClass me-2"><i class="bi @statusIcon me-1"></i>@Model.Status</span>
        @Model.SubjectName · @Model.FileType
    </p>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="app-card">
            <div class="app-card-header">
                <i class="bi bi-info-circle me-2" style="color:var(--c-indigo-light)"></i>Thông tin file
            </div>
            <div class="card-body">
                <dl class="row detail-list mb-0">
                    <dt class="col-sm-4">Tên file</dt>
                    <dd class="col-sm-8">
                        <code style="font-family:'JetBrains Mono',monospace;font-size:.88em;background:var(--surface-2);padding:.2em .5em;border-radius:6px;">@Model.FileName</code>
                    </dd>

                    <dt class="col-sm-4">Loại</dt>
                    <dd class="col-sm-8"><span class="badge bg-light">@Model.FileType</span></dd>

                    <dt class="col-sm-4">Môn học</dt>
                    <dd class="col-sm-8" style="color:var(--c-indigo-light)">@Model.SubjectName</dd>

                    <dt class="col-sm-4">Chương</dt>
                    <dd class="col-sm-8">@(Model.ChapterTitle ?? "—")</dd>

                    <dt class="col-sm-4">Số chunk</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-primary" style="font-size:.85rem;">@Model.ChunkCount chunks</span>
                    </dd>

                    <dt class="col-sm-4">Trạng thái</dt>
                    <dd class="col-sm-8">
                        <span class="badge @bgClass"><i class="bi @statusIcon me-1"></i>@Model.Status</span>
                    </dd>

                    <dt class="col-sm-4">Upload lúc</dt>
                    <dd class="col-sm-8" style="color:var(--text-2);font-size:.9rem;">@Model.UploadedAt.ToLocalTime().ToString("g")</dd>

                    <dt class="col-sm-4">Xử lý xong</dt>
                    <dd class="col-sm-8 mb-0" style="color:var(--text-2);font-size:.9rem;">@(Model.ProcessedAt?.ToLocalTime().ToString("g") ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="app-card mb-4" style="border-color:rgba(99,102,241,.25);background:linear-gradient(135deg,rgba(99,102,241,.08) 0%,var(--surface-1) 100%);">
            <div class="app-card-header">
                <i class="bi bi-gear me-2" style="color:var(--c-indigo-light)"></i>Thao tác
            </div>
            <div class="card-body d-grid gap-3">
                <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-download me-2"></i> Tải file về máy
                </a>
                <form asp-action="Reindex" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn w-100" style="background:rgba(245,158,11,.15);border:1px solid rgba(245,158,11,.35);color:#fbbf24;border-radius:var(--radius-sm);">
                        <i class="bi bi-arrow-repeat me-2"></i> Index lại
                    </button>
                </form>
                <a asp-controller="Chat" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-chat-heart me-2"></i> Mở Chat AI
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Quay lại danh sách
                </a>
            </div>
        </div>

        @if (Model.Status == DocumentStatus.Indexed)
        {
            <div class="app-card" style="background:linear-gradient(135deg,rgba(16,185,129,.08) 0%,var(--surface-1) 100%);border-color:rgba(16,185,129,.25);">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <i class="bi bi-check-circle-fill" style="color:#34d399;font-size:1.1rem;"></i>
                        <strong style="color:#34d399;font-size:.9rem;">Sẵn sàng hỏi đáp</strong>
                    </div>
                    <p style="font-size:.82rem;color:var(--text-2);margin:0;">
                        Tài liệu này đã được lập chỉ mục. Vào Chat AI để hỏi đáp nội dung bài này.
                    </p>
                </div>
            </div>
        }
    </div>
</div>
