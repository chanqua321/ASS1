          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="④ DATA (2 nhánh)&#xa;• Model → SQL Server (Entity)&#xa;• Ngoài → Ollama HTTP / File disk" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="290" width="360" height="55" as="geometry" />
