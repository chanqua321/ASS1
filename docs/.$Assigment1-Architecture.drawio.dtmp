        <mxCell id="p2" value="② WEB — Controller&#xa;Nhận request → Validate → Map sang DTO" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="155" width="360" height="50" as="geometry" />
        </mxCell>
        <mxCell id="a02" style="endArrow=block;strokeWidth=2;strokeColor=#0066CC;" edge="1" parent="1" source="p2" target="p3">
