        <mxCell id="t8" value="LUỒNG REQUEST / RESPONSE HỢP LÝ (MVC 3 lớp)" style="text;html=1;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="15" width="550" height="35" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="Nguyên tắc:&#xa;• Web chỉ nhận HTTP + trả View/JSON/File&#xa;• Controller map ViewModel ↔ DTO, không xử lý nghiệp vụ&#xa;• Service xử lý logic, gọi DB / Ollama&#xa;• Model = Entity + DbContext" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="320" height="85" as="geometry" />
        </mxCell>
        <mxCell id="legend8" value="━━ Request (xuôi)  ┄┄ Response (ngược)" style="text;html=1;fontSize=12;fontStyle=2;" vertex="1" parent="1">
