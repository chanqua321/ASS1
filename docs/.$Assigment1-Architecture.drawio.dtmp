        </mxCell>
        <mxCell id="p1" value="① CLIENT&#xa;Browser gửi HTTP Request" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="90" width="360" height="45" as="geometry" />
        </mxCell>
