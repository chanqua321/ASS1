        </mxCell>
        <mxCell id="p3" value="③ SERVICE&#xa;Nghiệp vụ: Upload / RAG / Chat..." style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="520" y="225" width="360" height="50" as="geometry" />
