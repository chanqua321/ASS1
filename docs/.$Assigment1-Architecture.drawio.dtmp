            <mxPoint x="120" y="130" as="sourcePoint" />
            <mxPoint x="320" y="130" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="RES 200 HTML (UploadViewModel)" style="endArrow=open;dashed=1;strokeColor=#009900;fontColor=#009900;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="320" y="160" as="sourcePoint" />
            <mxPoint x="120" y="160" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="REQ POST /Documents/Upload&#xa;multipart/form-data" style="endArrow=block;strokeColor=#0066CC;fontColor=#0066CC;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
