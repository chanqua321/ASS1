        </mxCell>
        <mxCell id="leg5" value="━━ Request (xanh)   ┄┄ Response (xanh lá, đứt)   |   Web → Service (DTO) → Model (Entity)" style="text;html=1;fontSize=11;fontStyle=2;" vertex="1" parent="1">
