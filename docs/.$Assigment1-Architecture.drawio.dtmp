        <mxCell id="p2rl" value="View / JSON / File&#xa;HTTP 200 | 302 | 400 | 404" style="edgeLabel;fontSize=10;fontColor=#009900;align=left;" connectable="0" parent="a06">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="-30" y="-10" as="offset" />
