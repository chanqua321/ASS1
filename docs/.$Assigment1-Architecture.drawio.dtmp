        </mxCell>
        <mxCell id="wf1t" value="WF1 — UPLOAD TÀI LIỆU" style="swimlane;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;startSize=28;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="380" width="720" height="320" as="geometry" />
        </mxCell>
        <mxCell id="u1" value="REQ: GET /Documents/Upload&#xa;RES: 200 HTML (form chọn file + môn)" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf1t">
          <mxGeometry x="15" y="40" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="u2" value="REQ: POST /Documents/Upload (multipart)&#xa;• File, SubjectId/NewSubjectName, Chapter&#xa;RES thành công: 302 → /Documents/Index&#xa;RES lỗi: 200 HTML + ModelState error" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf1t">
          <mxGeometry x="15" y="100" width="330" height="85" as="geometry" />
        </mxCell>
        <mxCell id="u3" value="DTO: DocumentUploadRequest&#xa;→ DocumentService.UploadAsync()&#xa;→ DocumentListItemDto" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf1t">
          <mxGeometry x="370" y="40" width="330" height="70" as="geometry" />
        </mxCell>
        <mxCell id="u4" value="REQ: GET /Documents?subjectId=&#xa;RES: 200 HTML danh sách (Indexed)" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf1t">
          <mxGeometry x="15" y="200" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="u5" value="REQ: GET /Documents/Download/{id}&#xa;RES: 200 FileStream | 404 NotFound" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf1t">
          <mxGeometry x="370" y="130" width="330" height="50" as="geometry" />
        </mxCell>
        <mxCell id="wf2t" value="WF2 — CHAT RAG" style="swimlane;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;startSize=28;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="800" y="380" width="760" height="320" as="geometry" />
        </mxCell>
        <mxCell id="c1" value="REQ: GET /Chat/Index&#xa;RES: 200 HTML (danh sách phiên)" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf2t">
          <mxGeometry x="15" y="40" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c2" value="REQ: POST /Chat/Create (form)&#xa;RES: 302 → /Chat/Session/{guid}" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf2t">
          <mxGeometry x="15" y="100" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c3" value="REQ: GET /Chat/Session/{id}&#xa;RES: 200 HTML + lịch sử tin nhắn" style="rounded=1;fillColor=#e6f2ff;strokeColor=#0066CC;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf2t">
          <mxGeometry x="15" y="160" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c4" value="REQ: POST /Chat/Send (JSON) ★&#xa;Body: { sessionId, question, subjectId }" style="rounded=1;fillColor=#0066CC;fontColor=#ffffff;align=left;spacingLeft=8;fontSize=11;fontStyle=1;" vertex="1" parent="wf2t">
          <mxGeometry x="15" y="220" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="c5" value="Service nội bộ (ChatSendRequest DTO):&#xa;1. Lưu User → Model (Entity)&#xa;2. RetrieveAsync → Model (chunks)&#xa;3. GenerateAsync → Ollama (HTTP)&#xa;4. Lưu Assistant + Citations → Model&#xa;5. Trả ChatSendResponse (DTO)" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="wf2t">
          <mxGeometry x="390" y="40" width="355" height="120" as="geometry" />
        </mxCell>
        <mxCell id="c6" value="RES: 200 JSON ChatSendResponse&#xa;{ sessionId, userMessage,&#xa;  assistantMessage + citations,&#xa;  answeredFromDocuments }&#xa;RES lỗi: 400 { error }" style="rounded=1;fillColor=#e6ffe6;strokeColor=#009900;align=left;spacingLeft=8;fontSize=11;fontStyle=1;" vertex="1" parent="wf2t">
          <mxGeometry x="390" y="165" width="355" height="100" as="geometry" />
        </mxCell>
        <mxCell id="codes" value="MÃ HTTP hợp lý&#xa;200 OK — thành công (HTML/JSON/File)&#xa;302 Found — redirect sau POST&#xa;400 Bad Request — validate / lỗi nghiệp vụ&#xa;404 Not Found — id không tồn tại" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="400" height="100" as="geometry" />
        </mxCell>
        <mxCell id="dto-box" value="RANH GIỚI DTO / ENTITY&#xa;• Web nhận: ViewModel (form) hoặc JSON body&#xa;• Controller → Service: DTO (ChatSendRequest, DocumentUploadRequest)&#xa;• Service → Model: Entity qua AppDbContext&#xa;• Service → Ollama: HTTP JSON (không qua Model project)&#xa;• Controller → Browser: View / JSON DTO — KHÔNG trả Entity" style="rounded=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="480" y="720" width="560" height="110" as="geometry" />
        </mxCell>
        <mxCell id="tab-guide" value="Hướng dẫn đọc: Tab 8 (tổng quan) → Tab 5 (Upload sequence) → Tab 6 (Chat+AI sequence) → Tab 7 (bảng API)" style="text;html=1;fontStyle=2;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="850" width="700" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
